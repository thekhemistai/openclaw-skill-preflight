{
  "name": "@thekhemistai/skill-preflight",
  "version": "1.0.3",
  "type": "module",
  "description": "Injects relevant skills and protocols into OpenClaw agent context using Ollama embeddings (nomic-embed-text). Local-only when Ollama is local; remote ollamaBaseUrl sends text to that host.",
  "main": "dist/index.js",
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md",
    "SKILL.md"
  ],
  "keywords": [
    "openclaw",
    "plugin",
    "rag",
    "skills",
    "embeddings",
    "nomic-embed-text",
    "ollama",
    "agent"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/thekhemistai/openclaw-skill-preflight"
  },
  "homepage": "https://clawhub.ai",
  "author": "Chemdawg"
}
